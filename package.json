{
  "name": "number-guess-game",
  "version": "2.3.0",
  "description": "数字对决 Pro - 数字推理对战游戏，支持人机对战、双人联机和微信小游戏",
  "main": "index.html",
  "scripts": {
    "test": "jest && playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:jest": "jest",
    "test:e2e": "playwright test",
    "dev": "npx http-server -p 8080",
    "build": "node scripts/build.js",
    "build:css": "cleancss -o dist/css/styles.min.css css/styles.css",
    "build:js": "terser js/app.js js/ai.js js/network.js js/sound.js -o dist/js/bundle.min.js --compress --mangle",
    "build:html": "html-minifier --collapse-whitespace --remove-comments --minify-css true --minify-js true -o dist/index.html index.html"
  },
  "keywords": [
    "game",
    "number-guess",
    "pwa"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "clean-css-cli": "^5.6.3",
    "html-minifier-terser": "^7.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "terser": "^5.31.0"
  }
}
