/* components/keyboard/keyboard.wxss */

.keyboard {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx;
  background-color: var(--bg-secondary);
  border-radius: 24rpx;
}

.keyboard-row {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.key {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
  transition: all 0.15s ease;
}

.key:active {
  transform: scale(0.95);
  background-color: var(--accent-primary);
  color: white;
}

.key.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.key.highlight {
  background-color: var(--success-bg);
  border-color: var(--success);
  color: var(--success);
}

.action-row {
  margin-top: 8rpx;
}

.action-key {
  flex: 1;
  max-width: 200rpx;
  font-size: 28rpx;
}

.action-key.primary {
  background: var(--accent-gradient);
  color: white;
  border: none;
}

.action-key.disabled {
  opacity: 0.5;
  pointer-events: none;
}