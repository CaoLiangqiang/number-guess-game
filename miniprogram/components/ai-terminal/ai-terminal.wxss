/* components/ai-terminal/ai-terminal.wxss */

.terminal {
  background-color: #1a1a2e;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #2d2d44;
  font-family: 'SF Mono', Monaco, 'Courier New', monospace;
}

.terminal.thinking {
  border-color: var(--accent-primary);
  box-shadow: 0 0 20rpx rgba(99, 102, 241, 0.3);
}

.terminal-header {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #16162a;
  border-bottom: 1rpx solid #2d2d44;
}

.terminal-dots {
  display: flex;
  gap: 8rpx;
  margin-right: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.red {
  background-color: #ff5f56;
}

.dot.yellow {
  background-color: #ffbd2e;
}

.dot.green {
  background-color: #27ca40;
}

.terminal-title {
  font-size: 22rpx;
  color: #6b7280;
}

.terminal-body {
  padding: 16rpx;
  min-height: 120rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.terminal-line {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.line-prefix {
  color: #6b7280;
  margin-right: 8rpx;
  font-size: 24rpx;
}

.line-content {
  font-size: 24rpx;
  color: #e5e7eb;
  word-break: break-all;
}

.line-content.info {
  color: #60a5fa;
}

.line-content.success {
  color: #34d399;
}

.line-content.warning {
  color: #fbbf24;
}

.line-content.error {
  color: #f87171;
}

.line-content.processing {
  color: #a78bfa;
}

.thinking-line {
  display: flex;
  align-items: center;
}

.cursor {
  display: inline-block;
  width: 16rpx;
  height: 24rpx;
  background-color: #a78bfa;
  margin-left: 4rpx;
  animation: blink 1s step-end infinite;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.terminal-footer {
  display: flex;
  gap: 24rpx;
  padding: 12rpx 16rpx;
  background-color: #16162a;
  border-top: 1rpx solid #2d2d44;
}

.stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #6b7280;
}

.stat-value {
  font-size: 22rpx;
  color: #a78bfa;
  font-weight: 600;
}