/* components/rank-item/rank-item.wxss */

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.rank-item.is-me {
  background-color: var(--bg-secondary);
  border: 2rpx solid var(--accent-primary);
}

.rank-number {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-muted);
  margin-right: 16rpx;
}

.medal {
  font-size: 36rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.nickname {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.extra {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.value-section {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--accent-primary);
}

.unit {
  font-size: 22rpx;
  color: var(--text-secondary);
}