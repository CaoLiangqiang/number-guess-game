<!--components/guess-history/guess-history.wxml-->
<view class="history-container">
  <view class="history-header" wx:if="{{title}}">
    <text class="history-title">{{title}}</text>
  </view>

  <scroll-view
    scroll-y
    class="history-scroll"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
  >
    <view
      class="history-item {{item.isLatest ? 'latest' : ''}}"
      wx:for="{{history}}"
      wx:key="id"
      id="item-{{index}}"
    >
      <view class="guess-digits">
        <view
          class="digit {{digitClass}}"
          wx:for="{{item.guess}}"
          wx:for-item="digit"
          wx:for-index="dIndex"
          wx:key="dIndex"
        >
          {{digit}}
        </view>
      </view>
      <view class="guess-result">
        <view class="result-badge hit" wx:if="{{item.hits > 0}}">
          <text>{{item.hits}}A</text>
        </view>
        <view class="result-badge blow" wx:if="{{item.blows > 0}}">
          <text>{{item.blows}}B</text>
        </view>
        <view class="result-badge none" wx:if="{{item.hits === 0 && item.blows === 0}}">
          <text>-</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{history.length === 0}}">
      <text>{{emptyText || '暂无记录'}}</text>
    </view>
  </scroll-view>
</view>