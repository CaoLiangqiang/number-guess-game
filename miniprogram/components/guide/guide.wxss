/* components/guide/guide.wxss */

.guide-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.guide-content {
  width: 85%;
  max-width: 600rpx;
  background-color: var(--bg-card);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
}

.step-indicator {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--bg-secondary);
  transition: all 0.3s ease;
}

.step-dot.active {
  background-color: var(--accent-primary);
  width: 32rpx;
  border-radius: 8rpx;
}

.step-content {
  text-align: center;
  margin-bottom: 48rpx;
}

.step-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.step-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.step-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.step-example {
  margin-top: 24rpx;
  padding: 16rpx;
  background-color: var(--bg-secondary);
  border-radius: 12rpx;
  text-align: left;
}

.example-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.example-content {
  font-family: 'SF Mono', Monaco, monospace;
  font-size: 28rpx;
  color: var(--accent-primary);
}

.guide-actions {
  display: flex;
  gap: 24rpx;
}

.skip-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: var(--bg-secondary);
  color: var(--text-secondary);
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.next-btn {
  flex: 2;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--accent-gradient);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}