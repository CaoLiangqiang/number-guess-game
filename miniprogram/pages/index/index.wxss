/* index.wxss - 首页样式 */

.container {
  padding: 32rpx;
  min-height: 100vh;
  background-color: var(--bg-primary);
}

/* 用户信息区 */
.user-section {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: var(--bg-secondary);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid var(--accent-primary);
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 登录提示 */
.login-prompt {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.login-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

/* 游戏入口 */
.game-entrance {
  margin-bottom: 32rpx;
}

.entrance-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.entrance-card:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.card-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.card-arrow {
  font-size: 48rpx;
  color: var(--text-muted);
}

.badge {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  background-color: var(--success);
  color: white;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 快速设置 */
.quick-settings {
  padding: 32rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.setting-row:not(:last-child) {
  border-bottom: 1rpx solid var(--border-color);
}

.setting-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.difficulty-selector {
  display: flex;
  gap: 16rpx;
}

.difficulty-option {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
}

.difficulty-option.active {
  background: var(--accent-gradient);
  color: white;
  border-color: transparent;
}

/* 新手引导入口 */
.guide-entry {
  display: flex;
  justify-content: center;
  padding: 32rpx;
  margin-top: 32rpx;
}

.guide-text {
  font-size: 28rpx;
  color: var(--accent-primary);
  text-decoration: underline;
}