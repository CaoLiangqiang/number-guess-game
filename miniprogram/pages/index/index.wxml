<!--index.wxml - 首页-->
<view class="container dark-theme">
  <!-- 用户信息区 -->
  <view class="user-section" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '玩家'}}</text>
      <view class="stats">
        <text class="stat-item">胜率: {{stats.winRate}}%</text>
        <text class="stat-item">连胜: {{stats.winStreak}}</text>
      </view>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view class="login-prompt" wx:else>
    <button class="btn-primary login-btn" bindtap="handleLogin">
      微信登录
    </button>
  </view>

  <!-- 游戏入口 -->
  <view class="game-entrance">
    <!-- AI对战 -->
    <view class="entrance-card card" bindtap="startAIGame">
      <view class="card-icon">🤖</view>
      <view class="card-content">
        <text class="card-title">AI 对战</text>
        <text class="card-desc">与智能 AI 对决，锻炼推理能力</text>
      </view>
      <view class="card-arrow">›</view>
    </view>

    <!-- 每日挑战 -->
    <view class="entrance-card card" bindtap="startDailyChallenge">
      <view class="card-icon">🎯</view>
      <view class="card-content">
        <text class="card-title">每日挑战</text>
        <text class="card-desc">{{dailyChallenge.status === 'completed' ? '今日已完成' : '每天一题，挑战极限'}}</text>
      </view>
      <view class="card-arrow">›</view>
      <view class="badge" wx:if="{{dailyChallenge.status === 'completed'}}">✓</view>
    </view>

    <!-- 好友对战 -->
    <view class="entrance-card card" bindtap="goToLobby">
      <view class="card-icon">👥</view>
      <view class="card-content">
        <text class="card-title">好友对战</text>
        <text class="card-desc">邀请好友，实时对决</text>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>

  <!-- 快速设置 -->
  <view class="quick-settings card">
    <text class="card-title">快速设置</text>
    <view class="setting-row">
      <text class="setting-label">难度</text>
      <view class="difficulty-selector">
        <view
          class="difficulty-option {{settings.difficulty === 3 ? 'active' : ''}}"
          bindtap="setDifficulty"
          data-value="3"
        >3位</view>
        <view
          class="difficulty-option {{settings.difficulty === 4 ? 'active' : ''}}"
          bindtap="setDifficulty"
          data-value="4"
        >4位</view>
        <view
          class="difficulty-option {{settings.difficulty === 5 ? 'active' : ''}}"
          bindtap="setDifficulty"
          data-value="5"
        >5位</view>
      </view>
    </view>
    <view class="setting-row">
      <text class="setting-label">音效</text>
      <switch checked="{{settings.soundEnabled}}" bindchange="toggleSound" color="#6366f1" />
    </view>
  </view>

  <!-- 新手引导入口 -->
  <view class="guide-entry" bindtap="showGuide" wx:if="{{!guideCompleted}}">
    <text class="guide-text">📖 查看游戏规则</text>
  </view>
</view>