<!--error.wxml - 错误页面-->
<view class="container dark-theme">
  <view class="error-content">
    <text class="error-icon">{{icon}}</text>
    <text class="error-title">{{title}}</text>
    <text class="error-message">{{message}}</text>
    <button class="btn-primary" bindtap="retry" wx:if="{{canRetry}}">重试</button>
    <button class="btn-secondary" bindtap="goHome">返回首页</button>
  </view>
</view>