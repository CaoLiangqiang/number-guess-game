/* game.wxss - 游戏页面样式 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 24rpx;
  box-sizing: border-box;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.status-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* AI区域 */
.ai-section {
  margin-bottom: 24rpx;
}

.ai-terminal {
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid var(--accent-primary);
}

.ai-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.ai-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.ai-title {
  font-size: 28rpx;
  color: var(--accent-primary);
  font-weight: 500;
}

.ai-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ai-status {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-family: 'SF Mono', Monaco, monospace;
}

.ai-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--bg-secondary);
  border-top-color: var(--accent-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-top: 16rpx;
}

/* 历史记录区 */
.history-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.history-list {
  flex: 1;
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  padding: 16rpx;
  max-height: 400rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 12rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
}

.guess-number {
  display: flex;
  gap: 8rpx;
}

.guess-digit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  background-color: var(--bg-input);
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  font-family: 'SF Mono', Monaco, monospace;
}

.guess-result {
  display: flex;
  gap: 8rpx;
}

.result-hit {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--success);
  background-color: var(--success-bg);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.result-blow {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--warning);
  background-color: var(--warning-bg);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.result-none {
  font-size: 28rpx;
  color: var(--text-muted);
}

.empty-history {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: var(--text-muted);
  font-size: 28rpx;
}

/* 输入区域 */
.input-section {
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  padding: 24rpx;
}

.input-display {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.digit-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background-color: var(--bg-input);
  border: 4rpx solid var(--border-color);
  border-radius: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: 'SF Mono', Monaco, monospace;
  transition: all 0.2s;
}

.digit-box.filled {
  border-color: var(--accent-primary);
  background-color: var(--bg-card);
}

.digit-box.active {
  border-color: var(--accent-secondary);
  box-shadow: 0 0 0 4rpx rgba(129, 140, 248, 0.3);
}

/* 键盘 */
.keyboard {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.keyboard-row {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.key {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}

.key:active {
  background-color: var(--accent-primary);
  color: white;
}

.key.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.action-row {
  margin-top: 8rpx;
}

.action-key {
  width: 200rpx;
  font-size: 28rpx;
}

.action-key.primary {
  background: var(--accent-gradient);
  color: white;
  border: none;
}

/* 结果弹窗 */
.result-content {
  padding: 24rpx;
}

.result-stats {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.result-stats:last-child {
  border-bottom: none;
}

.result-label {
  color: var(--text-secondary);
  font-size: 28rpx;
}

.result-value {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.result-value.secret {
  font-family: 'SF Mono', Monaco, monospace;
  letter-spacing: 4rpx;
  color: var(--accent-primary);
}