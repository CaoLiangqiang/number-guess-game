/* room.wxss - 游戏房间样式 */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 32rpx;
}

/* 房间信息 */
.room-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  margin-bottom: 32rpx;
}

.room-code-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.room-code {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--accent-primary);
  letter-spacing: 16rpx;
  font-family: 'SF Mono', Monaco, monospace;
}

.room-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

/* 玩家区域 */
.players-section {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.player-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background-color: var(--bg-secondary);
  border-radius: 24rpx;
  min-width: 240rpx;
}

.player-slot.empty {
  border: 2rpx dashed var(--border-color);
}

.player-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.empty-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

.player-name {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.player-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.player-tag.host {
  background-color: var(--accent-bg);
  color: var(--accent-primary);
}

.player-tag.guest {
  background-color: var(--warning-bg);
  color: var(--warning);
}

.vs-divider {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-muted);
}

/* 设置区域 */
.settings-section {
  margin-bottom: 32rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.setting-row text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.difficulty-selector {
  display: flex;
  gap: 12rpx;
}

.diff-option {
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
}

.diff-option.active {
  background: var(--accent-gradient);
  color: white;
  border-color: transparent;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 48rpx;
}

/* 等待提示 */
.waiting-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
}

.waiting-tip text {
  font-size: 26rpx;
  color: var(--text-secondary);
}