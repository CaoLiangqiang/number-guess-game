/* lobby.wxss - 联机大厅样式 */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 32rpx;
}

/* 功能入口 */
.actions-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 16rpx;
}

/* 快速匹配 */
.quick-match {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.quick-match:active {
  opacity: 0.8;
}

.match-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.match-content {
  flex: 1;
}

.match-arrow {
  font-size: 48rpx;
  color: var(--text-muted);
}

/* 在线玩家 */
.players-section {
  background-color: var(--bg-secondary);
  border-radius: 24rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.player-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.player-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.player-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.player-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.player-info {
  flex: 1;
}

.player-name {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.player-status {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.invite-btn {
  background: var(--accent-gradient);
  color: white;
  border: none;
  font-size: 24rpx;
}

.empty-list {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: var(--text-muted);
}

/* 加入房间弹窗 */
.join-dialog {
  padding: 32rpx;
}

/* 匹配中弹窗 */
.matching-dialog {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
}

.matching-tip {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.cancel-match-btn {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: var(--text-muted);
  background: transparent;
  border: none;
}