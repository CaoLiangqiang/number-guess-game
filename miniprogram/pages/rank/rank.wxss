/* rank.wxss - 排行榜样式 */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
}

.rank-list {
  padding: 24rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.rank-number {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-muted);
  margin-right: 16rpx;
}

.rank-number.top-1 {
  color: #FFD700;
}

.rank-number.top-2 {
  color: #C0C0C0;
}

.rank-number.top-3 {
  color: #CD7F32;
}

.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.rank-info {
  flex: 1;
}

.rank-name {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.rank-value {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.empty-list {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: var(--text-muted);
}

.my-rank {
  margin: 24rpx;
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
}

.my-rank .rank-item {
  background-color: var(--bg-card);
  border: 2rpx solid var(--accent-primary);
}

.my-rank .rank-item.myself {
  margin-bottom: 0;
}