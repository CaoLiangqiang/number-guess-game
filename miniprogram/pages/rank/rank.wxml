<!--rank.wxml - 排行榜页面-->
<view class="container dark-theme">
  <!-- 排行榜切换 -->
  <van-tabs active="{{ activeTab }}" bind:change="onTabChange" color="#6366f1">
    <van-tab title="胜率榜" name="winRate">
      <view class="rank-list">
        <view class="rank-item" wx:for="{{winRateList}}" wx:key="openid">
          <view class="rank-number {{index < 3 ? 'top-' + (index + 1) : ''}}">
            <text>{{index + 1}}</text>
          </view>
          <image class="rank-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}"></image>
          <view class="rank-info">
            <text class="rank-name">{{item.nickname}}</text>
            <text class="rank-value">胜率 {{item.value}}%</text>
          </view>
        </view>
        <view class="empty-list" wx:if="{{winRateList.length === 0}}">
          <text>暂无数据</text>
        </view>
      </view>
    </van-tab>

    <van-tab title="连胜榜" name="winStreak">
      <view class="rank-list">
        <view class="rank-item" wx:for="{{winStreakList}}" wx:key="openid">
          <view class="rank-number {{index < 3 ? 'top-' + (index + 1) : ''}}">
            <text>{{index + 1}}</text>
          </view>
          <image class="rank-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}"></image>
          <view class="rank-info">
            <text class="rank-name">{{item.nickname}}</text>
            <text class="rank-value">{{item.value}}连胜</text>
          </view>
        </view>
        <view class="empty-list" wx:if="{{winStreakList.length === 0}}">
          <text>暂无数据</text>
        </view>
      </view>
    </van-tab>

    <van-tab title="今日挑战" name="daily">
      <view class="rank-list">
        <view class="rank-item" wx:for="{{dailyList}}" wx:key="openid">
          <view class="rank-number {{index < 3 ? 'top-' + (index + 1) : ''}}">
            <text>{{index + 1}}</text>
          </view>
          <image class="rank-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}"></image>
          <view class="rank-info">
            <text class="rank-name">{{item.nickname}}</text>
            <text class="rank-value">{{item.steps}}步 / {{item.duration}}秒</text>
          </view>
        </view>
        <view class="empty-list" wx:if="{{dailyList.length === 0}}">
          <text>今日暂无挑战者</text>
        </view>
      </view>
    </van-tab>
  </van-tabs>

  <!-- 我的排名 -->
  <view class="my-rank card" wx:if="{{myRank}}">
    <text class="card-title">我的排名</text>
    <view class="rank-item myself">
      <view class="rank-number">
        <text>{{myRank.rank}}</text>
      </view>
      <image class="rank-avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}"></image>
      <view class="rank-info">
        <text class="rank-name">{{userInfo.nickName || '我'}}</text>
        <text class="rank-value">{{myRank.displayValue}}</text>
      </view>
    </view>
  </view>
</view>