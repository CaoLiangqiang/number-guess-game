/* profile.wxss - 个人中心样式 */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 32rpx;
}

/* 用户卡片 */
.user-card {
  margin-bottom: 24rpx;
}

.user-header {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid var(--accent-primary);
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-muted);
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--accent-gradient);
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
}

/* 统计卡片 */
.stats-card {
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background-color: var(--bg-secondary);
  border-radius: 12rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent-primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 菜单列表 */
.menu-list {
  margin-top: 24rpx;
}

/* 设置面板 */
.settings-sheet {
  padding: 32rpx;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  text-align: center;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.difficulty-selector {
  display: flex;
  gap: 12rpx;
}

.diff-option {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  background-color: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
}

.diff-option.active {
  background: var(--accent-gradient);
  color: white;
  border-color: transparent;
}